  "formulas": [
    {
      "name": "Categorical task score",
      "formula": "1[predicted = objective or human-modal target]",
      "detail": "Exact agreement with an objective answer, or with the modal human answer when the target is a response distribution."
    },
    {
      "name": "Slider task score",
      "formula": "max(0, 1 - |prediction - target| / (maximum - minimum))",
      "detail": "Range-normalized absolute-error score; raw MAE and RMSE remain available per study."
    },
    {
      "name": "Multi-select task score",
      "formula": "2 * precision * recall / (precision + recall)",
      "detail": "Set F1 over selected option indices."
    },
    {
      "name": "Identity quality",
      "formula": "|predicted IDs intersection expected IDs| / |predicted IDs union expected IDs|",
      "detail": "Jaccard agreement against the README and manifest object contract."
    },
    {
      "name": "Temporal mask coverage",
      "formula": "mean_objects(visible sampled frames / sampled frames)",
      "detail": "Measures sustained mask support rather than frame-zero detection."
    },
    {
      "name": "Symbolic center quality",
      "formula": "1 / (1 + mean Euclidean pixel error / 10)",
      "detail": "Applied only when independent, frame-aligned symbolic center trajectories exist."
    },
    {
      "name": "Relation and event quality",
      "formula": "|predicted labels intersection target labels| / |predicted labels union target labels|",
      "detail": "Label-set Jaccard agreement, applied only when independent symbolic relation or event labels exist."
    },
    {
      "name": "Camera quality",
      "formula": "max(0, 1 - roundtrip error pixels / 1.5)",
      "detail": "Projection and unprojection must agree within the 1.5-pixel acceptance scale."
    },
    {
      "name": "Lifted point support",
      "formula": "min(1, minimum valid mask points / 50)",
      "detail": "Requires geometry to be supported by SAM-mask pixels lifted through VGGT-Omega."
    },
    {
      "name": "Kabsch rigidity quality",
      "formula": "max(0, 1 - normalized residual / 0.15)",
      "detail": "Scores accepted local SE(3) estimates against the rigid-consistency residual threshold."
    },
    {
      "name": "Hamrick Sim(3) center quality",
      "formula": "max(0, 1 - aligned center error / 0.10)",
      "detail": "Prediction geometry is aligned to hidden tower geometry for evaluation only; GT never repairs the code."
    },
    {
      "name": "Hamrick Sim(3) size quality",
      "formula": "max(0, 1 - aligned relative size error / 0.25)",
      "detail": "Uses the accepted 0.25 relative-size error scale after diagnostic Sim(3) alignment."
    },
    {
      "name": "Hamrick Sim(3) orientation quality",
      "formula": "max(0, 1 - aligned orientation error degrees / 30)",
      "detail": "Uses the accepted 30-degree orientation error scale after diagnostic Sim(3) alignment."
    },
    {
      "name": "Internal 4D quality",
      "formula": "mean(measured applicable internal normalized metrics)",
      "detail": "GT-referenced metrics are excluded; unsupported or not-applicable metrics remain null."
    },
    {
      "name": "GT quality",
      "formula": "mean(measured applicable GT-referenced normalized metrics)",
      "detail": "Reported separately from internal consistency and only where an independent comparison target exists."
    },
    {
      "name": "Quality coverage",
      "formula": "measured applicable metrics / applicable metrics",
      "detail": "Prevents a high score over a small measurable subset from being mistaken for complete evaluation."
    },
    {
      "name": "4D-code confidence",
      "formula": "C_code(q) = min over required evidence-group scores",
      "detail": "Each evidence group is also minimized across every code required by the question; missing evidence is zero."
    },
    {
      "name": "LLM answer confidence",
      "formula": "p_i = exp(z_i / T) / sum_j exp(z_j / T)",
      "detail": "The selected answer likelihood uses five-fold out-of-fold temperature scaling when calibration is supported."
    },
    {
      "name": "Human slider reliability",
      "formula": "r_SB = 2r / (1 + r)",
      "detail": "Spearman-Brown corrected split-half reliability over 200 deterministic response splits."
    },
    {
      "name": "Human categorical reliability",
      "formula": "mean(split-half modal agreement)",
      "detail": "Agreement of modal categorical responses across 200 deterministic participant splits."
    },
    {
      "name": "Routing gap",
      "formula": "oracle-tool task score - native-tool task score",
      "detail": "The 95% interval uses 1,000 grouped bootstrap resamples by experiment."
    }
  ]
